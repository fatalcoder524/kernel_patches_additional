From f373febe50b89763e6e8726a1311728e39249138 Mon Sep 17 00:00:00 2001
From: fatalcoder524 <11532648+fatalcoder524@users.noreply.github.com>
Date: Thu, 11 Jun 2026 20:24:31 +0530
Subject: [PATCH] Enable volume input to enable bbg efisp patch

---
 anykernel.sh | 89 ++++++++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 89 insertions(+)

diff --git a/anykernel.sh b/anykernel.sh
index 7ac0233..be54fde 100644
--- a/anykernel.sh
+++ b/anykernel.sh
@@ -50,6 +50,93 @@ $ksu_supported || abort "  -> Non-GKI device, abort."
 # boot install
 split_boot
 
+SELECTED_STR="  [->] Selected:"
+KEY_RESULT=""
+
+find_input_device() {
+  for dev in /dev/input/event*; do
+    if getevent -p "$dev" 2>/dev/null | grep -qE "KEY_VOLUMEUP|KEY_VOLUMEDOWN"; then
+      echo "$dev"
+      return 0
+    fi
+  done
+  echo "/dev/input/event2" # Fallback
+}
+
+INPUT_DEV=$(find_input_device)
+
+handle_input() {
+  while true; do
+    local event=$(getevent -lqc "$INPUT_DEV" 2>/dev/null | grep -m1 'DOWN')
+    case "$event" in
+    *KEY_VOLUMEUP*)
+      KEY_RESULT="up"
+      return 0
+      ;;
+    *KEY_VOLUMEDOWN*)
+      KEY_RESULT="down"
+      return 0
+      ;;
+    esac
+  done
+}
+
+show_menu() {
+  local selected=1
+  local total=$#
+  if [ $total -eq 2 ]; then
+    while true; do
+      handle_input
+      case "$KEY_RESULT" in
+      "up") return 1 ;;
+      "down") return 2 ;;
+      esac
+    done
+  else
+    while true; do
+      eval "local current=\"\$$selected\""
+      ui_print "➔ $current"
+      ui_print " "
+      handle_input
+      case "$KEY_RESULT" in
+      "up") selected=$((selected % total + 1)) ;;
+      "down")
+        ui_print "$SELECTED_STR $current"
+        return $selected
+        ;;
+      esac
+    done
+  fi
+}
+
+MENU_OPTIONS="Yes No"
+
+PATCH_CMDLINE=0
+ui_print " "
+ui_print "=========================================="
+ui_print " Are you using efisp exploit and require "
+ui_print " whitelisting abl and efisp partitions?   "
+ui_print "------------------------------------------"
+ui_print " 1. Yes. Whitelist abl and efisp!        "
+ui_print " 2. No. Keep as is!                      "
+ui_print "                                         "
+ui_print "        [VOL+] - Yes | [VOL-] - No       "
+ui_print "=========================================="
+ui_print " "
+show_menu $MENU_OPTIONS
+case $? in
+    1) PATCH_CMDLINE=1 ;;
+    2) PATCH_CMDLINE=0 ;;
+esac
+
+if [ $PATCH_CMDLINE == 1 ]; then
+    ui_print "Patching cmdline to allow abl and efisp flashing!!!"
+    patch_cmdline "oplusboot.secure_user_mode" "oplusboot.secure_user_mode=0"
+else
+    ui_print "Flashing the kernel as is with full BBG security!!!"
+    patch_cmdline "oplusboot.secure_user_mode" ""
+fi
+
 if [ -f "$SPLITIMG/ramdisk.cpio" ]; then
     unpack_ramdisk
     write_boot
@@ -57,6 +144,8 @@ else
     flash_boot
 fi
 
+killall getevent 2>/dev/null
+
 ui_print " "
 ui_print "WildKernels Telegram Channel:"
 ui_print "https://t.me/WildKernelsTG"
-- 
